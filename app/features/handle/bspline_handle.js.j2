// === BSPLINE HANDLE ===
const sectionWidth = {{ section_width }};
const sectionHeight = {{ section_height }};
const lowerAttachZ = {{ lower_attach_z }};
const upperAttachZ = {{ upper_attach_z }};
const lowerAttachX = {{ lower_attach_x }};
const upperAttachX = {{ upper_attach_x }};
const handleSpanZ = {{ handle_span_z }};
const handleOutwardDepth = {{ handle_outward_depth }};
const handleMidZ = {{ handle_mid_z }};
const handleMidOuterR = {{ handle_mid_outer_r }};

const halfSectionWidth = sectionWidth / 2;   // 장반경: X방향 (반경 방향)
const halfSectionHeight = sectionHeight / 2;  // 단반경: Z방향 (컵 높이 방향)

const lowerControlZ = lowerAttachZ + handleSpanZ * 0.22;
const upperControlZ = upperAttachZ - handleSpanZ * 0.03;

// 섹션: 타원 (직선 변 없음 → Null Face 수학적으로 불가능)
// GC_MakeEllipse: 장반경 >= 단반경 필요
const _ellipse = new oc.GC_MakeEllipse(
  new oc.gp_Ax2(new oc.gp_Pnt(0, 0, 0), new oc.gp_Dir(0, 0, 1)),
  halfSectionWidth,   // 장반경 (X방향, 7mm)
  halfSectionHeight   // 단반경 (Y방향 → Rx후 Z방향, 4mm)
).Value();
const _ellipseEdge = new oc.BRepBuilderAPI_MakeEdge(_ellipse).Edge();
const _ellipseWire = new oc.BRepBuilderAPI_MakeWire(_ellipseEdge).Wire();
let handleSection = new oc.BRepBuilderAPI_MakeFace(_ellipseWire).Face();

// 장축을 Z방향(= XY경로의 Frenet B방향)으로 정렬
// Ry(90°): XZ 평면 안에서 회전 → 장축 X → Z (컵 높이 방향)
// 최종 Rx(90°) 후: Z → -Y(수평 둘레 방향) → "가로로 붙음"
handleSection = Rotate([0, 1, 0],  90, handleSection, false);
handleSection = Translate([lowerAttachX, lowerAttachZ, 0], handleSection, false);

// 경로: Z 좌표 → Y 좌표로 (XY 평면, Z=0)
let path = BSpline([
  [lowerAttachX,                                lowerAttachZ, 0],
  [lowerAttachX - handleOutwardDepth * 0.7,    lowerControlZ, 0],
  [-handleMidOuterR - handleOutwardDepth,       handleMidZ,    0],
  [upperAttachX - handleOutwardDepth * 0.7,    upperControlZ, 0],
  [upperAttachX,                                upperAttachZ,  0],
]);

let cupHandle = Pipe(handleSection, path);
// Rx(90°): Y→Z, Z→-Y → 손잡이를 XY 평면에서 XZ 평면(컵 측면)으로 세움
cupHandle = Rotate([1, 0, 0], 90, cupHandle, false);

// 컵 외형 솔리드로 손잡이 트리밍 → 끝면이 컵 외벽 곡면과 일치
// 이후 +X 방향으로 1mm 이동 → 컵 벽 안쪽으로 살짝 겹치게 해서 Union 안정화
const _outerBottomR = {{ outer_bottom_r }};
const _outerTopR = {{ outer_top_r }};
const _cupHeight = {{ height }};
let _outerProfile = new Sketch([0, 0, 0])
  .LineTo([-_outerBottomR, 0])
  .LineTo([-_outerTopR, _cupHeight])
  .LineTo([0, _cupHeight])
  .End(true)
  .Face(true);
let _cupOuter = Revolve(_outerProfile, 360, [0, 1, 0], false, false);
_cupOuter = Rotate([1, 0, 0], 90, _cupOuter, false);
cupHandle = Difference(cupHandle, [_cupOuter], false);
cupHandle = Translate([1, 0, 0], cupHandle, false);
