// === BSPLINE HANDLE ===
const sectionWidth = {{ section_width }};
const sectionHeight = {{ section_height }};
const lowerAttachZ = {{ lower_attach_z }};
const upperAttachZ = {{ upper_attach_z }};
const lowerAttachX = {{ lower_attach_x }};
const upperAttachX = {{ upper_attach_x }};
const handleSpanZ = {{ handle_span_z }};
const handleOutwardDepth = {{ handle_outward_depth }};
const handleMidZ = {{ handle_mid_z }};
const handleMidOuterR = {{ handle_mid_outer_r }};

const halfSectionWidth = sectionWidth / 2;
const halfSectionHeight = sectionHeight / 2;

const lowerControlZ = lowerAttachZ + handleSpanZ * 0.22;
const upperControlZ = upperAttachZ - handleSpanZ * 0.03;

let handleSection = new Sketch([-halfSectionWidth, -halfSectionHeight, 0])
  .LineTo([halfSectionWidth, -halfSectionHeight])
  .LineTo([halfSectionWidth, halfSectionHeight])
  .LineTo([-halfSectionWidth, halfSectionHeight])
  .End(true)
  .Face(true);

// XY 평면 전략: 경로를 XY 평면에 그린 뒤 Rx(90°)로 XZ로 세움
// → 경로 탄젠트가 항상 XY 내에 있어 Z방향 섹션 변과 절대 평행하지 않음
// → Null Face 없음

// 섹션: Rx(-90°)로 XZ 평면에 배치 (법선 = +Y, 높이 = Z방향)
handleSection = Rotate([1, 0, 0], -90, handleSection, false);
// XY 경로의 시작점에 배치: (attachX, attachZ, 0)
handleSection = Translate([lowerAttachX, lowerAttachZ, 0], handleSection, false);

// 경로: Z 좌표 → Y 좌표로 (XY 평면, Z=0)
let path = BSpline([
  [lowerAttachX,                                lowerAttachZ, 0],
  [lowerAttachX - handleOutwardDepth * 0.7,    lowerControlZ, 0],
  [-handleMidOuterR - handleOutwardDepth,       handleMidZ,    0],
  [upperAttachX - handleOutwardDepth * 0.7,    upperControlZ, 0],
  [upperAttachX,                                upperAttachZ,  0],
]);

let cupHandle = Pipe(handleSection, path);
// Rx(90°): Y→Z, Z→-Y → 손잡이를 XY 평면에서 XZ 평면(컵 측면)으로 세움
cupHandle = Rotate([1, 0, 0], 90, cupHandle, false);
